{
  "redirects": [
    {
      "source": "/",
      "destination": "https://butterflychallenge.net/",
      "permanent": false
    },
    {
      "source": "/:path*",
      "destination": "https://butterflychallenge.net/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|src/|node_modules/|@|assets/|public/|.*\\..*).+)",
      "destination": "/index.html"
    }
  ]
}
